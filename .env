#MINERU
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
MODELSCOPE_CACHE=your_modelscope_cache_location
HF_HOME=your_huggingface_cache_location
MD_ROOT_DIR=./temp-files/


# api_key申请地址：https://bailian.console.aliyun.com/cn-beijing/?spm=5176.29597918.J_SEsSjsNv72yRuRFS2VknO.2.4d877b08ThdGtP&tab=model#/api-key
# 大模型的文档地址：https://bailian.console.aliyun.com/cn-beijing/?spm=5176.29597918.J_SEsSjsNv72yRuRFS2VknO.2.4d877b08ThdGtP&tab=doc#/doc
# Qwen3系列Flash模型，实现思考模式和非思考模式的有效融合，可在对话中切换模式。复杂推理类任务性能优秀，指令遵循、文本理解等能力显著提高。支持1M上下文长度，按照上下文长度进行阶梯计费。
LLM_DEFAULT_MODEL=qwen-flash
#Qwen3系列小尺寸视觉理解模型，实现思考模式和非思考模式的有效融合，效果优于开源版Qwen3-VL-30B-A3B，响应速度快。全面升级图像/视频理解，支持长视频长文档等超长上下文、
#空间感知与万物识别；具备视觉2D/3D定位能力，胜任复杂现实任务。
VL_MODEL=qwen3-vl-flash
OPENAI_API_KEY=your_aliqwen_apikey
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_TEMPERATURE=0.1

# embedding模型！ 进行向量生成！！ 魔搭下载模型到本地！！
BGE_M3_PATH=your_BGE_bge-m3_location
BGE_M3=BAAI/bge-m3
# gpu BGE_DEVICE=cuda:0  cpu
BGE_DEVICE=cpu
# cpu 需要关闭 0  GPU 上生成向量通常默认开启了半精度浮点数（FP16）加速，而 CPU 上通常使用单精度（FP32）
BGE_FP16=0
ITEM_NAME_DIAG=1

# Milvus 配置
# 切换成你milvus的url地址
MILVUS_URL=http://your_milvus_url:19530
# 存储切片集合
CHUNKS_COLLECTION=rag_chunks
# 存储每个文档对应的实体类
ITEM_NAME_COLLECTION=rag_item_names

EMBEDDING_DIM=1024


#Mongodb的配置
MONGO_URL=mongodb://your_mongodb_url:27017
MONGO_DB_NAME=rag_sessions

#minio客户端
MINIO_ENDPOINT=your_minio_url:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rag-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# 重排序模型配置
BGE_RERANKER_LARGE=your_BGE_reranker_large_location
#BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_DEVICE=cpu
#BGE_RERANKER_FP16=1
BGE_RERANKER_FP16=0


MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse


# mineru api以及url处理地址！
MINERU_API_TOKEN=your_mineru_token
MINERU_BASE_URL=https://mineru.net/api/v4

# ===================== 日志配置 =====================
# 控制台日志：True=开启/False=关闭，级别可选(DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO

# 日志配置
# 文件日志：True=开启/False=关闭，级别与控制台可独立设置
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
# 日志文件保留天数（自动删除过期日志，避免磁盘占满）
LOG_FILE_RETENTION=7 days

# ====================
# Graph Database (Neo4j)
# ====================
# Neo4j 连接 URI
NEO4J_URI=bolt://your_url:7687
# 数据库名（社区版固定）
NEO4J_DATABASE=neo4j
# 用户名
NEO4J_USERNAME=neo4j
# 密码
NEO4J_PASSWORD=your_neo4j_password

# 实体名称集合名
# ENTITY_NAME_COLLECTION=kb_graph_entity_names_v1
ENTITY_NAME_COLLECTION=neo4j_graph_entity
